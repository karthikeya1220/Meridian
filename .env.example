# Required: OpenAI API key for the enrichment LLM call (server-only)
# NEVER commit your real secret key to source control. Use .env.local for local dev.
OPENAI_API_KEY=sk-...

# Required: Secret token to protect the /api/enrich endpoint (server-only)
# The server will validate incoming requests contain this value in the
# `x-enrich-token` header. Choose a long random string in production.
ENRICH_SECRET=your-random-secret-here

# Required (client-visible): Must match ENRICH_SECRET for the prototype client
# so the EnrichmentPanel can call the API. NOTE: NEXT_PUBLIC_* variables are
# exposed to the browser and are not a secure mechanism for production auth.
NEXT_PUBLIC_ENRICH_SECRET=your-random-secret-here

# Optional: Override the web extractor base URL used to fetch page text.
# Default: https://r.jina.ai
EXTRACTOR_BASE=https://r.jina.ai
